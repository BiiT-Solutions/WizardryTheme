{
  "name": "@biit-solutions/storybook",
  "version": "1.24.1",
  "license": "AGPLv3",
  "author": "BiiT Sourcing Solutions",
  "scripts": {
    "clean": "git clean -fdx && npm install",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build-library": "npm run transloco:extract && ng build wizardry-theme",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "transloco:clean": "del-cli --force ./src/assets/i18n/wizardry-theme",
    "transloco:extract": "npm run transloco:clean && transloco-scoped-libs",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "storybook": "npm run transloco:extract && npm run docs:json && ng run storybook:storybook",
    "storybook:fast": "ng run storybook:storybook",
    "build-storybook": "npm run transloco:extract && npm run docs:json && ng run storybook:build-storybook",
    "build-storybook:fast": "ng run storybook:build-storybook",
    "prepare-publication": "cp ./README.md ./storybook-static/ && echo \"{\\\"name\\\": \\\"`node -e \"console.log(require('./package.json').name);\"\n`\\\", \\\"version\\\": \\\"`node -e \"console.log(require('./package.json').version);\"\n`\\\"}\" > ./storybook-static/package.json",
    "prepare-translations": "cpx \"./src/assets/i18n/wizardry-theme/**/*.json\" \"./dist/wizardry-theme/assets/i18n/\"",
    "prepare-styles": "cpx \"./src/assets/styles/**/*.*\" \"./dist/wizardry-theme/assets/styles/\"",
    "generate-zip": "mkdir -p ./dist-zip && tar -zcvf ./dist-zip/storybook.gz ./storybook-static",
    "publish-storybook": "npm run build-storybook && npm run prepare-publication && npm publish --access=public ./storybook-static",
    "publish-library": "npm run build-library && npm run prepare-translations && npm run prepare-styles && npm publish --access=public ./dist/wizardry-theme/"
  },
  "private": false,
  "dependencies": {
    "@angular/animations": "20.3.23",
    "@angular/cdk": "^20.2.14",
    "@angular/common": "20.3.23",
    "@angular/compiler": "20.3.23",
    "@angular/core": "20.3.23",
    "@angular/forms": "20.3.23",
    "@angular/material": "^20.2.14",
    "@angular/material-moment-adapter": "^20.2.14",
    "@angular/platform-browser": "20.3.23",
    "@angular/platform-browser-dynamic": "20.3.23",
    "@angular/router": "20.3.23",
    "@biit-solutions/biit-icons-collection": "latest",
    "@ngneat/transloco-locale": "^5.1.1",
    "@perfectmemory/ngx-contextmenu": "^18.0.0",
    "@siemens/ngx-datatable": "^22.4.2",
    "angular-calendar": "~0.31.0",
    "apexcharts": "^3.37.1",
    "material-design-icons": "^3.0.1",
    "ng-apexcharts": "~1.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^9.0.0",
    "web-file-polyfill": "^1.0.4",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "20.3.26",
    "@angular/cli": "20.3.26",
    "@angular/compiler-cli": "20.3.23",
    "@babel/core": "^7.20.12",
    "@compodoc/compodoc": "^1.1.19",
    "@ngneat/transloco": "^5.0.0",
    "@ngneat/transloco-scoped-libs": "^5.0.3",
    "@storybook/addon-actions": "^7.6.24",
    "@storybook/addon-docs": "^7.6.24",
    "@storybook/addon-essentials": "^7.6.24",
    "@storybook/addon-interactions": "^7.6.24",
    "@storybook/addon-links": "^7.6.24",
    "@storybook/angular": "^7.6.24",
    "@storybook/builder-webpack5": "^7.6.24",
    "@storybook/testing-library": "^0.2.2",
    "@types/jasmine": "~4.3.0",
    "@types/uuid": "^9.0.2",
    "babel-loader": "^8.3.0",
    "cpx": "^1.5.0",
    "date-fns": "^2.30.0",
    "del-cli": "^5.0.0",
    "jasmine-core": "~4.5.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "ng-packagr": "^20.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^7.6.24",
    "typescript": "~5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BiiT-Solutions/WizardryTheme.git"
  }
}
